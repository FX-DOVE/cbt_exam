########################################
# Backend (.env)
########################################
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

MONGODB_URI=mongodb://127.0.0.1:27017/cbt_exam

JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=12h

# Comma-separated list of allowed frontend origins.
# For local Wi-Fi access, add BOTH localhost and your host laptop IP (example shown).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.50:5173

# Seed admin user (created on first backend start if not exists)
SEED_ADMIN_EMAIL=admin@cbt.local
SEED_ADMIN_PASSWORD=Admin123!

